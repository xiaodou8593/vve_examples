	},
	center:{
		<x,int,1w>, <y,int,1w>, <z,int,1w>
	},
	velocity:{
		<vx,int,1w>, <vy,int,1w>, <vz,int,1w>
	},
	angular_vec:{
		<angular_x,int,100w>,
		<angular_y,int,100w>,
		<angular_z,int,100w>
	},
	angular_len:<angular_len,int,100w>,
	uvw_coord:{
