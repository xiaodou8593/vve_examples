# test_car临时对象
_this:{
	engine:{
		<target_power,int>,
		<damp_x,int>,
		<damp_v,int>,
		<damp_k,int>,
		<damp_b,int>,
		<damp_f,int>,
		<v_max,int,1w>
	},
	mass:<mass,int,1>,
	tensor:{
		<tensor_xx,int,100>,
		<tensor_yy,int,100>,
		<tensor_zz,int,100>,
		<tensor_xy,int,100>,
		<tensor_xz,int,100>,
		<tensor_yz,int,100>
	},
	cube_shift_y:<cube_shift_y,int,1w>,
	nvec:{
